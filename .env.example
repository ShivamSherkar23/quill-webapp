POSTGRES_DB=database_name
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=replace-with-a-strong-local-password
POSTGRES_HOST=db (docker-compose service name or localhost)
POSTGRES_PORT=5432

SECRET_KEY=replace-with-a-long-random-secret

# Alternatively, provide full connection strings or secret files:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
# SECRET_KEY_FILE=/run/secrets/quill_secret_key
# POSTGRES_PASSWORD_FILE=/run/secrets/quill_postgres_password
